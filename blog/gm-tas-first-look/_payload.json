[{"data":1,"prerenderedAt":125},["ShallowReactive",2],{"blog-\u002Fblog\u002Fgm-tas-first-look":3},{"id":4,"title":5,"author":6,"body":7,"date":116,"description":117,"extension":118,"meta":119,"navigation":120,"path":121,"seo":122,"stem":123,"__hash__":124},"content\u002Fblog\u002Fgm-tas-first-look.md","First look at global mean surface temperature","ACCESS-NRI",{"type":8,"value":9,"toc":110},"minimark",[10,14,23,28,40,88,92,102],[11,12,5],"h1",{"id":13},"first-look-at-global-mean-surface-temperature",[15,16,17,18,22],"p",{},"The dashboard now pulls global mean surface temperature (",[19,20,21],"code",{},"tas",") from the latest\nparquet output. This is an early, prototype signal — expect the source and\nprocessing to change as runs progress.",[24,25,27],"h2",{"id":26},"what-youre-looking-at","What you're looking at",[15,29,30,31,36,37,39],{},"The plot on the ",[32,33,35],"a",{"href":34},"\u002F","dashboard"," shows the ",[19,38,21],{}," anomaly over time, loaded directly\nin the browser from the parquet source via DuckDB-WASM. You can zoom with the\nmouse wheel, pan by dragging, and double-click to reset.",[41,42,43,56],"table",{},[44,45,46],"thead",{},[47,48,49,53],"tr",{},[50,51,52],"th",{},"Field",[50,54,55],{},"Value",[57,58,59,70,80],"tbody",{},[47,60,61,65],{},[62,63,64],"td",{},"Variable",[62,66,67,69],{},[19,68,21],{}," (near-surface air temperature)",[47,71,72,75],{},[62,73,74],{},"Source",[62,76,77],{},[19,78,79],{},"gm_tas.pq",[47,81,82,85],{},[62,83,84],{},"Loader",[62,86,87],{},"DuckDB-WASM (client side)",[24,89,91],{"id":90},"next-steps","Next steps",[93,94,95,99],"ul",{},[96,97,98],"li",{},"Wire up additional derived indicators such as TCRE.",[96,100,101],{},"Replace the prototype source with the canonical CMIP7 catalogue entry.",[15,103,104,105,109],{},"If you have a CMIP7 update to share, see\n",[32,106,108],{"href":107},"\u002Fblog\u002Fwelcome-to-cmip7-updates","Welcome to CMIP7 updates"," for how to publish one.",{"title":111,"searchDepth":112,"depth":112,"links":113},"",2,[114,115],{"id":26,"depth":112,"text":27},{"id":90,"depth":112,"text":91},"2026-06-20","An early look at the global mean surface temperature anomaly from the latest CMIP7 runs.","md",{},true,"\u002Fblog\u002Fgm-tas-first-look",{"title":5,"description":117},"blog\u002Fgm-tas-first-look","k3ZB66KLH1afDbVM3ydUGZ4J4_8nmllP0QFwZUIRTTM",1783399829265]